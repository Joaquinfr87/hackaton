{
  "name": "hackaton",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "turbo run prisma:generate",
    "db:migrate": "pnpm --filter @hackaton/backend prisma:migrate",
    "db:studio": "pnpm --filter @hackaton/backend prisma:studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}

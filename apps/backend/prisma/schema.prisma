generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Incident {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String
  severity    String
  status      String   @default("reported")
  location    String
  reportedBy  String
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("incidents")
}
